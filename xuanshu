#!/bin/bash
# 玄姝 Agent — 一键启动脚本
set -e

PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$PROJECT_DIR"

# 检查 Python
PYTHON=""
for py in python3.11 python3.10 python3.12 python3; do
    if command -v "$py" &>/dev/null && "$py" -c "import sys; sys.exit(0 if sys.version_info >= (3,10) else 1)" 2>/dev/null; then
        PYTHON="$py"; break
    fi
done
if [ -z "$PYTHON" ]; then
    echo "[玄姝] 错误: 未找到 Python 3.10+，请先安装"; exit 1
fi

echo "╔══════════════════════════════════════╗"
echo "║       玄姝 Agent 启动中...          ║"
echo "╚══════════════════════════════════════╝"

# 虚拟环境
if [ ! -d ".venv" ]; then
    echo "[玄姝] 创建虚拟环境..."
    $PYTHON -m venv .venv
fi
source .venv/bin/activate

# 安装依赖
echo "[玄姝] 检查依赖..."
pip install -r requirements.txt -q

# 启动
echo "[玄姝] 启动服务 (端口 8901)..."
python frontend.py
