#!/bin/bash
# 玄姝 Agent 启动入口 — 像 Codex 一样进目录就能启动
set -e

# 自动定位项目根目录（脚本所在目录）
PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$PROJECT_DIR"

# 检查 Python
PYTHON=""
for py in python3 python3.11 python3.10 python3.12; do
    if command -v "$py" &>/dev/null; then
        PYTHON="$py"; break
    fi
done
if [ -z "$PYTHON" ]; then
    echo "[玄姝] 错误: 未找到 Python 3.10+，请先安装"; exit 1
fi

echo "╔══════════════════════════════════════╗"
echo "║       玄姝 Agent 启动中...          ║"
echo "╚══════════════════════════════════════╝"

# 安装依赖（仅首次需要）
echo "[玄姝] 检查依赖..."
$PYTHON -c "import flask" 2>/dev/null || {
    echo "[玄姝] 安装依赖: flask flask-cors requests openai"
    pip3 install flask flask-cors requests openai -q
}

# 检查 API Key
if [ -z "$OPENAI_API_KEY" ]; then
    echo "[玄姝] 提示: 未设置 OPENAI_API_KEY，将使用本地模拟模式"
fi

# 启动
echo "[玄姝] 启动服务..."
$PYTHON frontend.py &
PID=$!
sleep 2

echo ""
echo "╔══════════════════════════════════════╗"
echo "║  http://localhost:8900              ║"
echo "║  按 Ctrl+C 停止                     ║"
echo "╚══════════════════════════════════════╝"

trap "kill $PID 2>/dev/null; echo ''; echo '[玄姝] 已停止'; exit 0" INT TERM
wait
